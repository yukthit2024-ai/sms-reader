<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Font Size"
        android:textSize="18sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnDecreaseFont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A-"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvFontSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="16"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="#333333" />

        <Button
            android:id="@+id/btnIncreaseFont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A+"
            android:textSize="16sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.card.MaterialCardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#DDDDDD">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchConfirmDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm before deletion"
            android:textSize="18sp"
            android:textColor="#333333"
            android:padding="12dp" />
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnMakeDefaultSms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Make Default SMS App"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnOpenSystemSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open System Settings"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="How to set as default SMS app manually:"
        android:textSize="16sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Open System Settings\n2. Go to Apps &amp; notifications\n3. Tap on Default apps\n4. Tap on SMS app\n5. Select SMS Reader"
        android:textSize="14sp"
        android:textColor="#555555"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

</LinearLayout>
